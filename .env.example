# Baseline configurations for FlientSec services
# Copy to .env in production and replace with strong secrets

# Backend API endpoint configuration
BACKEND_URL=http://localhost:8000/api/v1
JWT_SECRET=default_secret_key_change_in_production

# PostgreSQL configuration
DATABASE_URL=postgresql://postgres:postgres@db:5432/flientsec
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=flientsec

# Cache and Queue system (Planned)
REDIS_URL=redis://redis:6379/0

# Logging level (debug, info, warn, error)
LOG_LEVEL=info
